# --- Common ---
API_KEY=nagent-dev-key

# --- Backend ---
# Get your API keys from respective providers
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Railway will provide these automatically when you add Postgres/Redis
DATABASE_URL=
REDIS_URL=

# Port (Railway sets this automatically)
PORT=8000

# --- Frontend ---
VITE_API_URL=https://your-backend-service.up.railway.app
VITE_WS_URL=wss://your-backend-service.up.railway.app
VITE_API_KEY=nagent-dev-key
